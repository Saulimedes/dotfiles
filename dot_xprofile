export GTK_IM_MODULE=xim
export QT_IM_MODULE=xim

setxkbmap -layout us -variant altgr-weur -option ctrl:nocaps

# Patch XKB keymap:
# - ; → dead_diaeresis (prefix for accented chars: ;a → ä, ;; → ;)
xkbcomp :0 - 2>/dev/null \
  | sed 's/\[       semicolon,           colon,     ocircumflex,     Ocircumflex \]/[ dead_diaeresis,           colon,     ocircumflex,     Ocircumflex ]/' \
  | xkbcomp -w 0 - :0 2>/dev/null

xset b off
